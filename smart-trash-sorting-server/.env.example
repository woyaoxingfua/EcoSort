# 服务器配置
PORT=3000
NODE_ENV=development

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=smart_trash_sorting

# JWT配置
JWT_SECRET=smart_trash_sorting_secret_key_2024
JWT_EXPIRES_IN=7d

# 微信小程序配置（替换为你自己的AppID和Secret）
WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here
WECHAT_DISABLE_MOCK_LOGIN=true

# 企业审核管理（可选，不填则不校验）
ADMIN_REVIEW_KEY=

# S3 对象存储（默认不启用）
S3_ENABLED=false
S3_ENDPOINT=https://your-s3-endpoint
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=your_bucket
S3_REGION=auto
S3_PUBLIC_URL=
