      {
        "pagePath": "pages/navigation/navigation",
        "text": "导航",
        "iconPath": "static/images/map.png",
        "selectedIconPath": "static/images/map-active.png"
      },
      {
        "pagePath": "pages/points/points",
        "text": "积分",
        "iconPath": "static/images/points.png",
        "selectedIconPath": "static/images/points-active.png"
      },
      {
        "pagePath": "pages/profile/profile",
