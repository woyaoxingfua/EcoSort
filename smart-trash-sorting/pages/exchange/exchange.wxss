/* pages/exchange/exchange.wxss */

.container {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 20rpx;
  font-size: 28rpx;
  color: #666;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #07c160;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

/* 内容列表 */
.content-list {
  flex: 1;
  padding: 20rpx;
}

/* 兑换卡片 */
.exchange-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s;
}

.exchange-card:active {
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.exchange-card.completed {
  opacity: 0.7;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.prize-icon {
  font-size: 56rpx;
  margin-right: 16rpx;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.prize-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.status {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  width: fit-content;
}

.status.pending {
  background: #ffbe00;
  color: #fff;
}

.status.completed {
  background: #07c160;
  color: #fff;
}

.arrow {
  font-size: 24rpx;
  color: #ccc;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12rpx;
  border-top: 2rpx solid #f0f0f0;
  font-size: 24rpx;
  color: #999;
}

.price {
  font-size: 28rpx;
  color: #fa5151;
  font-weight: 600;
}

/* 提示卡片 */
.tip-card {
  background: rgba(7, 193, 96, 0.1);
  border: 2rpx solid rgba(7, 193, 96, 0.2);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 26rpx;
  color: #07c160;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

/* 模态框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  z-index: -1;
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 30rpx 30rpx;
  max-height: 80vh;
  overflow-y: auto;
  position: relative;
}

.modal-close {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 40rpx;
  color: #999;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 详情部分 */
.detail-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.label {
  font-size: 26rpx;
  color: #999;
}

.value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 凭证框 */
.voucher-box {
  background: #f8f9fa;
  border: 2rpx dashed #07c160;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.voucher-code {
  font-size: 32rpx;
  font-weight: 600;
  color: #07c160;
  font-family: 'Courier New', monospace;
  letter-spacing: 2rpx;
}

.copy-btn {
  font-size: 24rpx;
  color: #07c160;
  padding: 8rpx 16rpx;
  border: 2rpx solid #07c160;
  border-radius: 8rpx;
}

.voucher-hint {
  font-size: 22rpx;
  color: #999;
}

.address-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 按钮组 */
.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.btn-primary,
.btn-secondary,
.btn-share {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s;
}

.btn-primary {
  background: #07c160;
  color: #fff;
  grid-column: 2;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-secondary {
  background: #f5f5f5;
  color: #07c160;
  border: 2rpx solid #07c160;
  grid-column: 1;
}

.btn-secondary:active {
  background: #f0f0f0;
}

.btn-share {
  background: #fff;
  color: #07c160;
  border: 2rpx solid #07c160;
  grid-column: 1 / -1;
  margin-top: 12rpx;
}

.btn-share:active {
  background: #f8f9fa;
}
