/* pages/points/points.wxss */

.container {
  min-height: 100vh;
  box-sizing: border-box;
}

.points-card {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.points-label {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 12rpx;
}

.points-value {
  display: block;
  font-size: 72rpx;
  font-weight: bold;
}

.checkin-info {
  text-align: center;
}

.checkin-days {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.checkin-btn {
  display: inline-block;
  padding: 16rpx 40rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.checkin-btn.checked {
  background: rgba(255,255,255,0.1);
}

/* 打卡进度 */
.checkin-progress {
  padding-top: 30rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.progress-days {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
}

.day-item.active {
  opacity: 1;
}

.day-circle {
  width: 48rpx;
  height: 48rpx;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.day-item.active .day-circle {
  background: #fff;
  color: #07c160;
}

.day-reward {
  font-size: 20rpx;
}

.progress-bar {
  height: 8rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: #fff;
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 排行榜入口 */
.ranking-entry {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.ranking-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.ranking-text {
  flex: 1;
  font-size: 28rpx;
  opacity: 0.9;
}

.ranking-arrow {
  font-size: 28rpx;
  opacity: 0.6;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  margin: 0 -20rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #07c160;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #07c160;
  border-radius: 2rpx;
}

/* 内容列表 */
.content-list {
  flex: 1;
  background: #fff;
  margin: 0 -20rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.exchange-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
}

.exchange-tip-text {
  font-size: 24rpx;
  color: var(--gray);
}

.exchange-tip-link {
  font-size: 24rpx;
  color: var(--primary);
  font-weight: 600;
}

/* 任务项 */
.task-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  opacity: 1;
}

.task-item.locked {
  opacity: 0.6;
}

.task-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.task-content {
  flex: 1;
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.task-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.task-points {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 600;
}

.task-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.task-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-text {
  font-size: 22rpx;
  color: #999;
}

.task-action {
  margin-left: 20rpx;
}

.action-btn {
  display: inline-block;
  padding: 12rpx 28rpx;
  background: #07c160;
  color: #fff;
  border-radius: 30rpx;
  font-size: 26rpx;
}

.action-btn.completed {
  background: #e0e0e0;
  color: #999;
}

.action-btn.locked {
  background: #f0f0f0;
  color: #ccc;
}

/* 奖品网格 */
.prize-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.prize-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  width: calc((100% - 20rpx) / 2);
  box-sizing: border-box;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.prize-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.prize-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.prize-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
  min-height: 68rpx;
  margin-bottom: 20rpx;
}

.prize-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  gap: 12rpx;
  margin-top: auto;
}

.prize-points {
  flex: 1;
  text-align: left;
  font-size: 28rpx;
  color: #fa5151;
  font-weight: 600;
}

.exchange-btn {
  min-width: 132rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 20rpx;
  background: #e0e0e0;
  color: #999;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: none;
  margin: 0;
}

.exchange-btn::after {
  border: none;
}

.exchange-btn.available {
  background: #07c160;
  color: #fff;
}

/* 积分记录 */
.record-section {
  margin-bottom: 20rpx;
}

.record-section:last-child {
  margin-bottom: 0;
}

.record-section-title {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin: 0 0 12rpx 6rpx;
}

.record-list {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 0 30rpx;
}

.record-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #e8e8e8;
}

.record-item:last-child {
  border-bottom: none;
}

.record-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.record-content {
  flex: 1;
}

.record-reason {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.record-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.record-points {
  font-size: 36rpx;
  font-weight: 600;
}

.record-points.add {
  color: #07c160;
}

.record-points.consume {
  color: #fa5151;
}

.exchange-meta {
  min-width: 120rpx;
  text-align: right;
}

.exchange-status {
  display: block;
  font-size: 22rpx;
  margin-top: 6rpx;
  color: var(--gray);
}

.exchange-status.status-pending {
  color: var(--warning);
}

.exchange-status.status-completed {
  color: var(--primary);
}

.exchange-status.status-cancelled {
  color: var(--danger);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
