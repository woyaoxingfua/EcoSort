/* pages/navigation/navigation.wxss */

.map-container {
  position: relative;
  height: 500rpx;
}

.map {
  width: 100%;
  height: 100%;
}

.locate-btn {
  position: absolute;
  right: 30rpx;
  bottom: 30rpx;
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.locate-icon {
  font-size: 40rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  gap: 16rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s;
}

.filter-item.active {
  background: #07c160;
  color: #fff;
}

/* 回收点列表 */
.point-list {
  flex: 1;
  background: #fff;
  padding: 20rpx;
}

.list-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.loading-tip,
.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.point-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.point-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.point-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.point-info {
  flex: 1;
}

.point-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.point-address {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.point-distance {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
}

.point-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
  margin-left: 68rpx;
}

.point-tag {
  font-size: 22rpx;
  color: #666;
  background: #e8e8e8;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.point-footer {
  display: flex;
  justify-content: space-between;
  margin-left: 68rpx;
}

.point-hours, .point-phone {
  font-size: 24rpx;
  color: #999;
}

.point-phone {
  color: #07c160;
}

/* 详情弹窗 */
.detail-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.detail-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
}

.detail-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.detail-body {
  margin-bottom: 30rpx;
}

.detail-row {
  margin-bottom: 24rpx;
}

.detail-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.detail-value {
  display: block;
  font-size: 30rpx;
  color: #333;
}

.detail-value.link {
  color: #07c160;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.detail-tag {
  font-size: 24rpx;
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
}

.detail-footer {
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}
