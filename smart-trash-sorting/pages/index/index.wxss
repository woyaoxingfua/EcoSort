/* pages/index/index.wxss */

/* 用户信息卡片 */
.user-card {
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  color: #fff;
  padding: 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.3);
}

.user-meta {
  flex: 1;
  margin-left: 20rpx;
}

.nickname {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
}

.checkin-days {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* 等级信息 */
.level-row {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
  gap: 12rpx;
}

.level-badge {
  font-size: 22rpx;
  background: rgba(255,255,255,0.25);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  white-space: nowrap;
}

.level-progress-bar {
  flex: 1;
  height: 10rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 5rpx;
  overflow: hidden;
  max-width: 180rpx;
}

.level-progress-fill {
  height: 100%;
  background: rgba(255,255,255,0.8);
  border-radius: 5rpx;
  transition: width 0.5s ease;
}

.checkin-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  font-size: 24rpx;
}

.checkin-btn.checked {
  background: rgba(255,255,255,0.1);
}

.checkin-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.points-box {
  display: flex;
  justify-content: space-around;
  padding-top: 30rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.points-item {
  text-align: center;
}

.points-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
}

.points-label {
  display: block;
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* 识别方式 */
.identify-ways {
  display: flex;
  justify-content: space-around;
}

.way-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
}

.way-icon {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #07c160 0%, #05a050 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
}

.way-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.way-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 垃圾分类 */
.types-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f8f9fa;
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.type-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.type-desc {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.type-examples {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.type-examples text {
  font-size: 22rpx;
  color: #999;
  background: #fff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* 热门搜索 */
.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
}

.hot-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.hot-name {
  font-size: 28rpx;
  color: #333;
  margin-right: 12rpx;
}

.hot-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  color: #fff;
}

/* 资讯 */
.news-card .card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.more {
  font-size: 26rpx;
  color: #07c160;
  font-weight: normal;
}

.news-list {
  border-top: 2rpx solid #f0f0f0;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.news-item:last-child {
  border-bottom: none;
}

.news-content {
  flex: 1;
}

.news-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.news-meta {
  display: flex;
  gap: 20rpx;
}

.news-source, .news-date {
  font-size: 24rpx;
  color: #999;
}

.news-arrow {
  color: #ccc;
  font-size: 32rpx;
  margin-left: 20rpx;
}

/* 环保小贴士 */
.eco-tips-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.eco-tips-content {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.eco-tips-icon {
  font-size: 64rpx;
  flex-shrink: 0;
}

.eco-tips-text {
  flex: 1;
}

.eco-tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.eco-tips-desc {
  display: block;
  font-size: 26rpx;
  line-height: 1.6;
  opacity: 0.9;
}
