/* pages/enterprise/enterprise.wxss */

/* 登录区域 */
.login-section {
  padding: 40rpx;
}

.login-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  color: #fff;
  margin-bottom: 40rpx;
}

.login-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}

.login-title {
  display: block;
  font-size: 40rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.login-desc {
  display: block;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 40rpx;
}

.login-card .btn-primary {
  background: #fff;
  color: #667eea;
  width: 80%;
}

.login-card .btn-secondary {
  background: transparent;
  color: rgba(255,255,255,0.8);
  width: 80%;
  margin-top: 16rpx;
  border: 2rpx solid rgba(255,255,255,0.4);
}

.login-card .btn-outline-light {
  background: transparent;
  color: #fff;
  width: 80%;
  margin-top: 16rpx;
  border: 2rpx solid rgba(255,255,255,0.7);
}

/* 登录表单 */
.login-form {
  margin-top: 30rpx;
  text-align: left;
}

.auth-entry {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-mode-switch {
  display: flex;
  background: rgba(255,255,255,0.2);
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.mode-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  padding: 12rpx 0;
  border-radius: 8rpx;
}

.mode-item.active {
  background: #fff;
  color: #667eea;
  font-weight: 600;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 12rpx;
}

.form-input {
  background: rgba(255,255,255,0.2);
  border: 2rpx solid rgba(255,255,255,0.3);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  color: #fff;
}

.form-input::placeholder {
  color: rgba(255,255,255,0.5);
}

.form-tips {
  text-align: center;
  margin-bottom: 24rpx;
}

.tips-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.feature-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.feature-info {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 企业区域 */
.enterprise-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 40rpx;
  color: #fff;
  margin-bottom: 20rpx;
}

.enterprise-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.enterprise-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
}

.enterprise-info {
  flex: 1;
}

.enterprise-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.enterprise-type {
  display: block;
  font-size: 26rpx;
  opacity: 0.9;
}

.verify-badge {
  background: rgba(255,255,255,0.2);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.enterprise-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid rgba(255,255,255,0.2);
}

.meta-item {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  gap: 20rpx;
}

.action-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-name {
  font-size: 26rpx;
  color: #666;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background: #fff;
  padding: 20rpx;
  margin: 0 -20rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #667eea;
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  background: #f5f5f5;
  margin: 0 -20rpx;
  padding: 20rpx;
}

/* 统计数据 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
  margin-bottom: 12rpx;
}

.stat-label {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 核销记录 */
.verify-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 0 30rpx;
}

.verify-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.verify-item:last-child {
  border-bottom: none;
}

.verify-user {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.user-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.user-name {
  font-size: 26rpx;
  color: #666;
}

.verify-detail {
  flex: 1;
}

.verify-item-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.verify-time {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.verify-points {
  font-size: 32rpx;
  color: #fa5151;
  font-weight: 600;
}

/* 图表卡片 */
.chart-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 30rpx;
}

.chart-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.bar-track {
  width: 60rpx;
  height: 200rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
}

.bar-fill {
  width: 100%;
  background: #667eea;
  border-radius: 8rpx;
  transition: height 0.5s;
}

.bar-label {
  font-size: 24rpx;
  color: #666;
  margin-top: 12rpx;
}

.bar-value {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 数据汇总 */
.data-summary {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  justify-content: space-around;
}

.summary-item {
  text-align: center;
}

.summary-label {
  display: block;
  font-size: 26rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.summary-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-value.up {
  color: #07c160;
}

/* 退出登录 */
.logout-btn {
  margin-top: 40rpx;
  background: #fff;
  color: #fa5151;
  border: 2rpx solid #fa5151;
  border-radius: 44rpx;
  font-size: 30rpx;
}
