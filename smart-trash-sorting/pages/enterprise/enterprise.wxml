<!--pages/enterprise/enterprise.wxml-->
<view class="container">
  <!-- 未登录状态 -->
  <view class="login-section" wx:if="{{!isLoggedIn}}">
    <view class="login-card">
      <text class="login-icon">🏢</text>
      <text class="login-title">企业端入口</text>
      <text class="login-desc">回收点入驻、积分核销、数据统计</text>
      
      <!-- 登录表单 -->
      <view class="login-form" wx:if="{{showLoginForm}}">
        <view class="auth-mode-switch">
          <text class="mode-item {{!isRegisterMode ? 'active' : ''}}" bindtap="switchToLoginForm">企业登录</text>
          <text class="mode-item {{isRegisterMode ? 'active' : ''}}" bindtap="showRegisterForm">企业入驻</text>
        </view>

        <block wx:if="{{!isRegisterMode}}">
          <view class="form-group">
            <text class="form-label">用户名</text>
            <input class="form-input" placeholder="请输入企业账号" value="{{loginUsername}}" bindinput="onUsernameInput" />
          </view>
          <view class="form-group">
            <text class="form-label">密码</text>
            <input class="form-input" placeholder="请输入密码" password="{{true}}" value="{{loginPassword}}" bindinput="onPasswordInput" bindconfirm="doLogin" />
          </view>
          <view class="form-tips">
            <text class="tips-text">测试账号: admin / 123456</text>
          </view>
          <button class="btn btn-primary" bindtap="doLogin" loading="{{loginLoading}}">登 录</button>
        </block>

        <block wx:else>
          <view class="form-group">
            <text class="form-label">企业名称 *</text>
            <input class="form-input" placeholder="请输入企业名称" value="{{registerName}}" bindinput="onRegisterNameInput" />
          </view>
          <view class="form-group">
            <text class="form-label">企业类型</text>
            <input class="form-input" placeholder="如：回收企业/环保服务" value="{{registerType}}" bindinput="onRegisterTypeInput" />
          </view>
          <view class="form-group">
            <text class="form-label">联系人</text>
            <input class="form-input" placeholder="请输入联系人" value="{{registerContactName}}" bindinput="onRegisterContactInput" />
          </view>
          <view class="form-group">
            <text class="form-label">联系电话</text>
            <input class="form-input" placeholder="请输入联系电话" value="{{registerPhone}}" bindinput="onRegisterPhoneInput" />
          </view>
          <view class="form-group">
            <text class="form-label">企业地址</text>
            <input class="form-input" placeholder="请输入企业地址" value="{{registerAddress}}" bindinput="onRegisterAddressInput" />
          </view>
          <view class="form-group">
            <text class="form-label">营业执照号</text>
            <input class="form-input" placeholder="请输入营业执照号" value="{{registerLicenseNo}}" bindinput="onRegisterLicenseInput" />
          </view>
          <view class="form-group">
            <text class="form-label">登录账号 *</text>
            <input class="form-input" placeholder="用于企业端登录" value="{{registerUsername}}" bindinput="onRegisterUsernameInput" />
          </view>
          <view class="form-group">
            <text class="form-label">登录密码 *</text>
            <input class="form-input" placeholder="请输入登录密码" password="{{true}}" value="{{registerPassword}}" bindinput="onRegisterPasswordInput" bindconfirm="doRegister" />
          </view>
          <button class="btn btn-primary" bindtap="doRegister" loading="{{registerLoading}}">提交入驻</button>
        </block>

        <button class="btn btn-secondary" bindtap="toggleLoginForm">取 消</button>
      </view>
      
      <view class="auth-entry" wx:else>
        <button class="btn btn-primary" bindtap="toggleLoginForm">企业登录</button>
        <button class="btn btn-outline-light" bindtap="showRegisterForm">企业入驻</button>
      </view>
    </view>
    
    <view class="feature-list">
      <view class="feature-item">
        <text class="feature-icon">📍</text>
        <view class="feature-info">
          <text class="feature-title">回收点入驻</text>
          <text class="feature-desc">提交资质，入驻平台获取更多客流</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📱</text>
        <view class="feature-info">
          <text class="feature-title">积分核销</text>
          <text class="feature-desc">扫码或输入核销码，快速完成兑换</text>
        </view>
      </view>
      <view class="feature-item">
        <text class="feature-icon">📊</text>
        <view class="feature-info">
          <text class="feature-title">数据统计</text>
          <text class="feature-desc">查看访问量、积分兑换等经营数据</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view class="enterprise-section" wx:if="{{isLoggedIn}}">
    <!-- 企业信息卡片 -->
    <view class="enterprise-card">
      <view class="enterprise-header">
        <view class="enterprise-avatar">🏢</view>
        <view class="enterprise-info">
          <text class="enterprise-name">{{enterpriseInfo.name}}</text>
          <text class="enterprise-type">{{enterpriseInfo.type}}</text>
        </view>
        <view class="verify-badge">已认证</view>
      </view>
      <view class="enterprise-meta">
        <text class="meta-item">📍 {{enterpriseInfo.address}}</text>
        <text class="meta-item">👤 {{enterpriseInfo.contact_name}}</text>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-actions">
      <view class="action-item" bindtap="scanToVerify">
        <text class="action-icon">📷</text>
        <text class="action-name">扫码核销</text>
      </view>
      <view class="action-item" bindtap="manualVerify">
        <text class="action-icon">⌨️</text>
        <text class="action-name">手动输入</text>
      </view>
      <view class="action-item" bindtap="viewSettings">
        <text class="action-icon">⚙️</text>
        <text class="action-name">店铺设置</text>
      </view>
    </view>

    <!-- 标签切换 -->
    <view class="tab-bar">
      <view class="tab-item {{activeTab === item.id ? 'active' : ''}}" 
            wx:for="{{tabs}}" 
            wx:key="id"
            data-tab="{{item.id}}"
            bindtap="switchTab">
        {{item.name}}
      </view>
    </view>

    <!-- 概览 -->
    <scroll-view class="content-area" scroll-y wx:if="{{activeTab === 'overview'}}">
      <view class="stats-grid">
        <view class="stat-card" bindtap="viewDataDetail" data-type="points">
          <text class="stat-value">{{stats.todayPoints}}</text>
          <text class="stat-label">今日核销积分</text>
        </view>
        <view class="stat-card" bindtap="viewDataDetail" data-type="visits">
          <text class="stat-value">{{stats.todayVisits}}</text>
          <text class="stat-label">今日访问量</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.totalPoints}}</text>
          <text class="stat-label">累计核销积分</text>
        </view>
        <view class="stat-card">
          <text class="stat-value">{{stats.totalVisits}}</text>
          <text class="stat-label">累计访问量</text>
        </view>
      </view>
    </scroll-view>

    <!-- 核销记录 -->
    <scroll-view class="content-area" scroll-y wx:if="{{activeTab === 'verify'}}">
      <view class="verify-list">
        <view class="verify-item" wx:for="{{verifyRecords}}" wx:key="id">
          <view class="verify-user">
            <text class="user-icon">👤</text>
            <text class="user-name">{{item.user}}</text>
          </view>
          <view class="verify-detail">
            <text class="verify-item-name">{{item.item}}</text>
            <text class="verify-time">{{item.time}}</text>
          </view>
          <text class="verify-points">-{{item.points}}</text>
        </view>
      </view>
    </scroll-view>

    <!-- 数据统计 -->
    <scroll-view class="content-area" scroll-y wx:if="{{activeTab === 'data'}}">
      <view class="chart-card">
        <view class="chart-title">月度积分核销趋势</view>
        <view class="chart-bars">
          <view class="bar-item" wx:for="{{monthlyData}}" wx:key="month">
            <view class="bar-track">
              <view class="bar-fill" style="height: {{item.points / 6000 * 200}}rpx"></view>
            </view>
            <text class="bar-label">{{item.month}}</text>
            <text class="bar-value">{{item.points}}</text>
          </view>
        </view>
      </view>
      
      <view class="data-summary">
        <view class="summary-item">
          <text class="summary-label">本月核销</text>
          <text class="summary-value">{{stats.totalPoints}} 积分</text>
        </view>
        <view class="summary-item">
          <text class="summary-label">本月访问</text>
          <text class="summary-value">{{stats.totalVisits}} 人次</text>
        </view>
      </view>
    </scroll-view>

    <!-- 退出登录 -->
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>
