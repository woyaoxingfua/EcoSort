/* pages/search/search.wxss */

.search-box {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.search-input-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 44rpx;
  padding: 0 30rpx;
  height: 88rpx;
  margin-right: 20rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  height: 100%;
}

.clear-icon {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx;
}

.search-btn {
  width: 120rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  border-radius: 44rpx;
  padding: 0;
  margin: 0;
}

/* 搜索结果 */
.result-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.clear-link {
  font-size: 26rpx;
  color: #999;
}

.result-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.result-content {
  flex: 1;
}

.result-name {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.result-tips {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.result-tag {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  color: #fff;
  font-size: 24rpx;
}

.tag-recyclable, .result-tag.tag-recyclable { background: #2c9678; }
.tag-hazardous, .result-tag.tag-hazardous { background: #e74c3c; }
.tag-kitchen, .result-tag.tag-kitchen { background: #8b6914; }
.tag-other, .result-tag.tag-other { background: #7f8c8d; }

/* 空结果 */
.empty-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.feedback-btn {
  background: #f5f5f5;
  color: #666;
  font-size: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
}

/* 标签列表 */
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: #f5f5f5;
  color: #666;
  padding: 16rpx 30rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.tag-history {
  background: #e8f5e9;
  color: #07c160;
}

/* 分类网格 */
.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.type-item {
  padding: 30rpx;
  border-radius: 16rpx;
  text-align: center;
  color: #fff;
}

.type-icon {
  display: block;
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.type-examples {
  display: block;
  font-size: 22rpx;
  opacity: 0.9;
}
